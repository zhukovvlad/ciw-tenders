# Облачный PostgreSQL (Neon / Supabase) с расширением pgvector.
# Драйвер psycopg v3: используйте схему postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.eu-central-1.aws.neon.tech/ciw?sslmode=require

# AI ключи
GOOGLE_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Параметры сопоставления
CONFIDENCE_THRESHOLD=0.90
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=claude-3-5-sonnet-20240620

# CORS (origin фронтенда)
FRONTEND_ORIGIN=http://localhost:5173

# Аутентификация (JWT). JWT_SECRET — длинная случайная строка, сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-long-random-string
JWT_EXPIRE_MINUTES=720

# Bootstrap первого администратора (используется `just create-admin`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
